<?xml version="1.0" encoding="utf-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">

  <Product
      Id="*"
      Name="GCode Preview Handler"
      Language="1033"
      Version="1.0.0.0"
      Manufacturer="Thane"
      UpgradeCode="F5F8C7F3-0C9E-4C0E-9E7E-8F4F0E0A1234">

    <Package InstallerVersion="500" Compressed="yes" InstallScope="perMachine" Platform="x64" />
    <MediaTemplate />
    <MajorUpgrade DowngradeErrorMessage="A newer version is already installed." />
 
 
    <!--
      Register/unregister the COM servers so Windows Explorer can load the
      shell extension. regsvr32 writes the CLSID keys that tell COM where
      to find the in-process server; the RegistryValue components below then
      wire the .nc/.gcode associations to those CLSIDs.
    -->
    <CustomAction Id="RegisterHandlerDll"
                  Directory="INSTALLDIR"
                  ExeCommand="[SystemFolder]regsvr32.exe /s &quot;[INSTALLDIR]GCodePreviewHandler.dll&quot;"
                  Execute="deferred"
                  Return="check"
                  Impersonate="no" />
    <CustomAction Id="RegisterControlDll"
                  Directory="INSTALLDIR"
                  ExeCommand="[SystemFolder]regsvr32.exe /s &quot;[INSTALLDIR]GCodePreviewControl.dll&quot;"
                  Execute="deferred"
                  Return="check"
                  Impersonate="no" />
    <CustomAction Id="UnregisterHandlerDll"
                  Directory="INSTALLDIR"
                  ExeCommand="[SystemFolder]regsvr32.exe /s /u &quot;[INSTALLDIR]GCodePreviewHandler.dll&quot;"
                  Execute="deferred"
                  Return="ignore"
                  Impersonate="no" />
    <CustomAction Id="UnregisterControlDll"
                  Directory="INSTALLDIR"
                  ExeCommand="[SystemFolder]regsvr32.exe /s /u &quot;[INSTALLDIR]GCodePreviewControl.dll&quot;"
                  Execute="deferred"
                  Return="ignore"
                  Impersonate="no" />

    <InstallExecuteSequence>
      <!-- Unregister before files are removed (uninstall or upgrade) -->
      <Custom Action="UnregisterControlDll"  Before="RemoveFiles">Installed AND (REMOVE="ALL" OR REINSTALL)</Custom>
      <Custom Action="UnregisterHandlerDll"  After="UnregisterControlDll">Installed AND (REMOVE="ALL" OR REINSTALL)</Custom>
      <!-- Register after files land on disk (install or upgrade) -->
      <Custom Action="RegisterHandlerDll"    After="InstallFiles">(NOT Installed) OR REINSTALL</Custom>
      <Custom Action="RegisterControlDll"    After="RegisterHandlerDll">(NOT Installed) OR REINSTALL</Custom>
    </InstallExecuteSequence>

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLDIR" Name="GCodePreviewHandler">

          <!-- Handler DLL + helper scripts -->
          <Component Id="cmpHandlerFiles" Guid="C4C8C2E4-6C4F-4F0B-9E1C-1B2E3C4D5E6F">
            <File Id="filHandlerDll"   Source="$(var.HandlerBin)\GCodePreviewHandler.dll" KeyPath="yes" />
            <File Id="filInstallPs1"   Source="..\install.ps1" />
            <File Id="filUninstallPs1" Source="..\uninstall.ps1" />
          </Component>

          <!-- Control DLL (was entirely absent from the original) -->
          <Component Id="cmpControlFiles" Guid="E6E7E8E9-EAEB-4ECD-8EEF-0E1E2E3E4E5E">
            <File Id="filControlDll" Source="$(var.ControlBin)\GCodePreviewControl.dll" KeyPath="yes" />
          </Component>

          <!--
            Shell-extension registry associations.
            Root/Key on RegistryValue handles the HKCR path correctly.
            The original had a fake <Directory Id="HKCR"> wrapper which is
            invalid WiX and also had an unclosed tag for .gcode — both fixed.
          -->
		  <Component Id="cmpNcPreviewReg" Guid="B1B2B3B4-B5B6-4B7B-8B9B-0B1B2B3B4B5B">
			  <RegistryValue
				Root="HKCR"
				Key=".nc\ShellEx\{8895b1c6-b41f-4c1c-a562-0d564250836f}"
				Type="string"
				Value="{A1C3F4D2-9B8E-4F1E-8C3C-2A1F0B9D1234}"
				KeyPath="yes" />
		  </Component>

          <Component Id="cmpGcodePreviewReg" Guid="A1A2A3A4-A5A6-4A7A-8A9A-0A1A2A3A4A5A">
			  <RegistryValue
				Root="HKCR"
				Key=".gcode\ShellEx\{8895b1c6-b41f-4c1c-a562-0d564250836f}"
				Type="string"
				Value="{A1C3F4D2-9B8E-4F1E-8C3C-2A1F0B9D1234}"
				KeyPath="yes" />
		  </Component>


        </Directory>
      </Directory>
    </Directory>

    <!-- Feature is required by WiX — original had none (guaranteed compile error) -->
    <Feature Id="ProductFeature" Title="GCode Preview Handler" Level="1">
      <ComponentRef Id="cmpHandlerFiles" />
      <ComponentRef Id="cmpControlFiles" />
      <ComponentRef Id="cmpNcPreviewReg" />
      <ComponentRef Id="cmpGcodePreviewReg" />
    </Feature>

  </Product>
</Wix>
