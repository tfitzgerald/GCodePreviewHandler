Windows Registry Editor Version 5.00

[HKEY_CLASSES_ROOT\.gcode]
@="GCodeFile"

[HKEY_CLASSES_ROOT\GCodeFile]
@="GCode File"

[HKEY_CLASSES_ROOT\GCodeFile\ShellEx]
[HKEY_CLASSES_ROOT\GCodeFile\ShellEx\{8895b1c6-b41f-4c1c-a562-0d564250836f}]
@="{33333333-3333-3333-3333-333333333333}"

[HKEY_CLASSES_ROOT\CLSID\{33333333-3333-3333-3333-333333333333}]
@="GCode Preview Handler"
"InprocServer32"="C:\\Program Files\\GCodePreviewHandler\\GCodePreviewHandler.dll"
"ThreadingModel"="Apartment"
