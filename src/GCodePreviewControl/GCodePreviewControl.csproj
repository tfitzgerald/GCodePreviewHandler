<Project ToolsVersion="15.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <Import Project="$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props" />

  <PropertyGroup>
	  <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
	  <Platform Condition=" '$(Platform)' == '' ">AnyCPU</Platform>
	  <ProjectGuid>{A1A1A1A1-A1A1-A1A1-A1A1-A1A1A1A1A1A1}</ProjectGuid>
	  <OutputType>Library</OutputType>
	  <RootNamespace>GCodePreviewControl</RootNamespace>
	  <AssemblyName>GCodePreviewControl</AssemblyName>
	  <TargetFrameworkVersion>v4.8</TargetFrameworkVersion>
	  <UseWPF>true</UseWPF>

	  <!-- REQUIRED FOR GITHUB ACTIONS -->
	  <BaseIntermediateOutputPath>obj\</BaseIntermediateOutputPath>
	  <BaseOutputPath>bin\</BaseOutputPath>
	  <OutputPath>bin\$(Configuration)\</OutputPath>
	  <IntermediateOutputPath>obj\$(Configuration)\</IntermediateOutputPath>
  </PropertyGroup>


  <ItemGroup>
    <Reference Include="System" />
    <Reference Include="System.Xaml" />
    <Reference Include="WindowsBase" />
    <Reference Include="PresentationCore" />
    <Reference Include="PresentationFramework" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="HelixToolkit.Wpf.SharpDX" Version="2.27.3" />
    <PackageReference Include="SharpDX" Version="4.2.0" />
  </ItemGroup>

  <Import Project="$(MSBuildToolsPath)\Microsoft.CSharp.targets" />
</Project>
